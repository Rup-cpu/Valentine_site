<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>this side Rup 💖</title>

<title>Valentine 💖</title>

<style>
body {
    margin: 0;
    height: 100vh;
    font-family: 'Comic Sans MS', cursive;
    display: flex;
    justify-content: center;
    align-items: center;
    background: linear-gradient(to right, black, #222);
    color: white;
    overflow: hidden;
    transition: 0.6s;
}

/* Main box */
.container {
    text-align: center;
}

h2 {
    color: #bbb;
}

h1 {
    font-size: 40px;
}

/* Buttons */
button {
    padding: 12px 25px;
    font-size: 18px;
    border: none;
    border-radius: 25px;
    cursor: pointer;
    margin: 10px;
    transition: 0.3s;
}

#yes {
    background: white;
    color: black;
}

#yes:hover {
    transform: scale(1.1);
}

#no {
    background: gray;
    color: white;
    position: absolute;
}

/* YES Screen */
#yesScreen {
    display: none;
    text-align: center;
    animation: fadeIn 1s ease;
}

#yesScreen h1 {
    font-size: 50px;
}

#yesScreen p {
    font-size: 20px;
}

/* Popup */
.popup {
    position: fixed;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.7);
    display: none;
    justify-content: center;
    align-items: center;
}

.popup-box {
    background: white;
    color: black;
    padding: 25px;
    border-radius: 20px;
    text-align: center;
}

.popup-box img {
    width: 150px;
}

/* Animations */
@keyframes fadeIn {
    from {opacity:0; transform: scale(0.7);}
    to {opacity:1; transform: scale(1);}
}

/* Floating hearts */
.heart {
    position: fixed;
    bottom: 0;
    font-size: 20px;
    animation: floatUp 5s linear infinite;
}

@keyframes floatUp {
    from {transform: translateY(0); opacity: 1;}
    to {transform: translateY(-800px); opacity: 0;}
}
</style>
</head>

<body>

<div class="container">
    <h2>Hi, it’s me Your Rup 💌</h2>
    <h1>Will You Be My Valentine? 💕</h1>

    <button id="yes">Yes 😍</button>
    <button id="no">No 😢</button>
</div>

<!-- YES SCREEN -->
<div id="yesScreen">
    <h1>Yayyy!! 😘💖</h1>
    <p>You just made my day ❤️</p>
</div>

<!-- NO POPUP -->
<div class="popup" id="popup">
    <div class="popup-box">
        <h2>😤 Why you messing up with me?</h2>
        <img src="https://media.giphy.com/media/JIX9t2j0ZTN9S/giphy.gif">
    </div>
</div>

<script>
const noBtn = document.getElementById("no");
const yesBtn = document.getElementById("yes");
const popup = document.getElementById("popup");

// Move button (works mobile + pc)
function moveButton() {
    const btnWidth = noBtn.offsetWidth;
    const btnHeight = noBtn.offsetHeight;

    const x = Math.random() * (window.innerWidth - btnWidth);
    const y = Math.random() * (window.innerHeight - btnHeight);

    noBtn.style.position = "absolute";
    noBtn.style.transition = "0.4s ease";
    noBtn.style.left = x + "px";
    noBtn.style.top = y + "px";
}

noBtn.addEventListener("mouseover", moveButton);
noBtn.addEventListener("touchstart", moveButton);

// YES CLICK
yesBtn.onclick = () => {
    document.body.style.background = "linear-gradient(135deg, #ff758c, #ff7eb3)";
    document.querySelector(".container").style.display = "none";
    document.getElementById("yesScreen").style.display = "block";

    startHearts();
};

// NO CLICK
noBtn.onclick = () => {
    popup.style.display = "flex";
};

// Close popup
popup.onclick = () => {
    popup.style.display = "none";
};

// Floating hearts
function startHearts() {
    setInterval(() => {
        const heart = document.createElement("div");
        heart.classList.add("heart");
        heart.innerHTML = "💖";
        heart.style.left = Math.random() * 100 + "vw";
        document.body.appendChild(heart);

        setTimeout(() => {
            heart.remove();
        }, 5000);
    }, 300);
}
</script>

</body>
</html>